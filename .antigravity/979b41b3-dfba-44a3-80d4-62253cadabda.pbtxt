          text: "                  <Shield size={12} className=\"text-emerald-500/70\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  <span>\305\236ifreleme modu: <span className=\"text-emerald-500 font-semibold font-mono\">CLIENT AES-GCM (256-bit)</span></span>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                  <Shield size={12} className=\"text-indigo-500/70\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <span>\305\236ifreleme modu: <span className=\"text-indigo-600 font-semibold font-mono\">CLIENT AES-GCM (256-bit)</span></span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <span>Mesajlar sunucuya asla d\303\274z metin olarak gitmez.</span>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          </motion.div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        )}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      </AnimatePresence>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
      }
    }
    instruction: "Apply Clean Minimalism design styling, colors, and layout borders to the existing UI of App.tsx"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-emerald-500/30 selection:text-emerald-300\">\n      \n      {/* Background ambient lock pattern */}\n      <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(16,185,129,0.05),transparent_40%)] pointer-events-none\" />\n\n      {/* Main container */}\n      <AnimatePresence mode=\"wait\">\n        {!roomConfig ? (\n          // ================== ACCESS / CONFIGURATION SCREEN ==================\n          <motion.div\n            key=\"login\"\n            initial={{ opacity: 0, y: 15 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: -15 }}\n            className=\"flex-1 flex items-center justify-center p-4 z-10\"\n          >\n            <div className=\"w-full max-w-md bg-slate-900/60 backdrop-blur-md border border-slate-800 rounded-2xl shadow-2xl overflow-hidden p-6 md:p-8\">\n              \n              {/* Security Shield Header */}\n              <div className=\"flex flex-col items-center text-center mb-6\">\n                <div className=\"p-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full mb-3 shadow-[0_0_15px_rgba(16,185,129,0.1)]\">\n                  <Shield size={32} />\n                </div>\n                <h1 className=\"text-2xl font-bold tracking-tight text-white font-sans\">Kripto Sohbet</h1>\n                <p className=\"text-xs text-slate-400 mt-1 max-w-sm\">\n                  U\303\247tan uca \305\237ifreli (E2EE), tamamen gizli ve anl\304\261k mesajla\305\237ma platformu. Sunucu mesajlar\304\261n\304\261z\304\261 asla okuyamaz.\n                </p>\n              </div>\n\n              {/* Informative Security Alert */}\n              <div className=\"mb-6 p-3 bg-slate-950 border border-slate-800 rounded-lg text-xs text-slate-400 flex items-start gap-2.5\">\n                <Info size={16} className=\"text-emerald-400 flex-shrink-0 mt-0.5\" />\n                <p className=\"leading-relaxed\">\n                  Mesajlar\304\261n\304\261z taray\304\261c\304\261da <span className=\"text-emerald-400 font-semibold font-mono\">AES-GCM 256-bit</span> ile \305\237ifrelenir.\n                  Arkada\305\237\304\261n\304\261zla ayn\304\261 <span className=\"text-emerald-400 font-semibold\">Ortak \305\236ifreyi</span> kullanarak mesajlar\304\261 an\304\261nda de\305\237ifre edebilirsiniz.\n                </p>\n              </div>\n\n              <form onSubmit={handleJoinRoom} className=\"space-y-4\">\n                {/* Username Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-slate-300 flex justify-between items-center\">\n                    <span>Rumuzunuz (Kullan\304\261c\304\261 Ad\304\261)</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setUsernameInput(generateRandomUsername())}\n                      className=\"text-[10px] text-emerald-400 hover:text-emerald-300 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> Rastgele \303\234ret\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <User size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-500\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={usernameInput}\n                      onChange={(e) => setUsernameInput(e.target.value)}\n                      placeholder=\"\303\226rn: G\303\266lgeAjan\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-slate-950/80 border border-slate-800 rounded-lg text-sm text-white placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 transition-colors font-sans\"\n                    />\n                  </div>\n                </div>\n\n                {/* Room ID Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-slate-300 flex justify-between items-center\">\n                    <span>Oda Ad\304\261 (Oda Kodu)</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setRoomInput(generateRandomRoomId())}\n                      className=\"text-[10px] text-emerald-400 hover:text-emerald-300 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> Rastgele Olu\305\237tur\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <Lock size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-500\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={roomInput}\n                      onChange={(e) => setRoomInput(e.target.value.toLowerCase().replace(/\\s+/g, \"-\"))}\n                      placeholder=\"\303\226rn: ozel-sohbet-odasi\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-slate-950/80 border border-slate-800 rounded-lg text-sm text-white placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 transition-colors font-mono\"\n                    />\n                  </div>\n                </div>\n\n                {/* Private Encryption Password Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-slate-300 flex justify-between items-center\">\n                    <span>Ortak \305\236ifreleme Anahtar\304\261</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setPasswordInput(generateRandomPassword())}\n                      className=\"text-[10px] text-emerald-400 hover:text-emerald-300 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> G\303\274\303\247l\303\274 \305\236ifre \303\234ret\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <Key size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-500\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={passwordInput}\n                      onChange={(e) => setPasswordInput(e.target.value)}\n                      placeholder=\"\305\236ifreleme anahtar\304\261n\304\261 buraya girin...\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-slate-950/80 border border-slate-800 rounded-lg text-sm text-white placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 transition-colors font-mono\"\n                    />\n                  </div>\n                </div>\n\n                {errorText && (\n                  <p className=\"text-rose-400 text-xs text-center font-medium mt-1\">\n                    {errorText}\n                  </p>\n                )}\n\n                <button\n                  type=\"submit\"\n                  className=\"w-full py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-semibold rounded-lg text-sm transition-all duration-200 active:scale-[0.98] shadow-lg shadow-emerald-500/20 flex items-center justify-center gap-2 mt-2 cursor-pointer\"\n                >\n                  <Lock size={16} /> G\303\274venli Giri\305\237 Yap\n                </button>\n              </form>\n            </div>\n          </motion.div>\n        ) : (\n          // ================== ACTIVE CHAT ROOM SCREEN ==================\n          <motion.div\n            key=\"chat\"\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            exit={{ opacity: 0 }}\n            className=\"flex-1 flex flex-col max-w-5xl w-full mx-auto p-3 md:p-6 z-10\"\n          >\n            {/* Upper Room Header Dashboard */}\n            <div className=\"bg-slate-900/80 backdrop-blur-md border border-slate-800 rounded-t-2xl p-4 flex flex-col md:flex-row gap-3 items-start md:items-center justify-between shadow-lg\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"p-2.5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-lg\">\n                  <Lock size={20} />\n                </div>\n                <div>\n                  <div className=\"flex items-center gap-2\">\n                    <h2 className=\"text-md font-bold text-white tracking-tight font-mono\">\n                      {roomConfig.roomId}\n                    </h2>\n                    <span\n                      className={`inline-block w-2.5 h-2.5 rounded-full ${\n                        sseStatus === \"connected\"\n                          ? \"bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]\"\n                          : sseStatus === \"connecting\"\n                          ? \"bg-amber-500 animate-pulse\"\n                          : \"bg-rose-500\"\n                      }`}\n                      title={\n                        sseStatus === \"connected\"\n                          ? \"Canl\304\261 ba\304\237lant\304\261 aktif\"\n                          : sseStatus === \"connecting\"\n                          ? \"Ba\304\237lant\304\261 kuruluyor...\"\n                          : \"Ba\304\237lant\304\261 koptu\"\n                      }\n                    />\n                  </div>\n                  <p className=\"text-xs text-slate-400 flex items-center gap-1.5 mt-0.5\">\n                    Rumuz: <span className=\"text-emerald-400 font-semibold\">{roomConfig.username}</span>\n                  </p>\n                </div>\n              </div>\n\n              {/* Action utilities */}\n              <div className=\"flex flex-wrap items-center gap-2 w-full md:w-auto\">\n                {/* Share Link Button */}\n                <button\n                  onClick={copyShareLink}\n                  className=\"flex-1 md:flex-initial flex items-center justify-center gap-1.5 px-3 py-1.5 bg-slate-950 hover:bg-slate-800 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium transition-colors cursor-pointer\"\n                >\n                  {copiedLink ? (\n                    <>\n                      <Check size={14} className=\"text-emerald-400\" />\n                      <span>Kopyaland\304\261!</span>\n                    </>\n                  ) : (\n                    <>\n                      <Share2 size={14} />\n                      <span>Davet Linki</span>\n                    </>\n                  )}\n                </button>\n\n                {/* Show Encryption Password Tooltip/Info */}\n                <button\n                  onClick={copyPasswordKey}\n                  className=\"flex-1 md:flex-initial flex items-center justify-center gap-1.5 px-3 py-1.5 bg-slate-950 hover:bg-slate-800 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium transition-colors font-mono cursor-pointer\"\n                  title=\"T\304\261klayarak \305\237ifreleme anahtar\304\261n\304\261 kopyalay\304\261n\"\n                >\n                  <Key size={13} className=\"text-emerald-400\" />\n                  <span>\305\236ifre:</span>\n                  <span className=\"text-slate-400 max-w-[80px] truncate\">{roomConfig.passwordKey}</span>\n                  {copiedKey ? <Check size={12} className=\"text-emerald-400 ml-1\" /> : <Copy size={11} className=\"text-slate-500 ml-1\" />}\n                </button>\n\n                {/* Reset room */}\n                <button\n                  onClick={handleClearHistory}\n                  className=\"p-1.5 bg-slate-950 hover:bg-rose-500/10 border border-slate-800 hover:border-rose-500/30 text-slate-400 hover:text-rose-400 rounded-lg transition-colors cursor-pointer\"\n                  title=\"Ge\303\247mi\305\237i Tamamen S\304\261f\304\261rla (Kendi Cihazlar\304\261nda ve Sunucuda)\"\n                >\n                  <Trash2 size={15} />\n                </button>\n\n                {/* Leave room */}\n                <button\n                  onClick={() => setRoomConfig(null)}\n                  className=\"flex items-center gap-1 px-3 py-1.5 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 hover:text-rose-300 border border-rose-500/20 hover:border-rose-500/30 rounded-lg text-xs font-semibold transition-colors cursor-pointer\"\n                >\n                  <LogOut size={13} />\n                  <span>\303\207\304\261k\304\261\305\237</span>\n                </button>\n              </div>\n            </div>\n\n            {/* Chat Body messages stream */}\n            <div className=\"flex-1 bg-slate-900/40 border-x border-slate-800 p-4 overflow-y-auto space-y-4 min-h-[350px] relative\">\n              {messages.length === 0 ? (\n                <div className=\"absolute inset-0 flex flex-col items-center justify-center p-6 text-center\">\n                  <div className=\"p-4 bg-emerald-500/5 rounded-full border border-emerald-500/10 mb-3 text-emerald-400/80\">\n                    <Unlock size={32} />\n                  </div>\n                  <h3 className=\"text-sm font-semibold text-slate-200\">Kripto Sohbet Odas\304\261 Haz\304\261r</h3>\n                  <p className=\"text-xs text-slate-400 mt-1 max-w-sm leading-relaxed\">\n                    Arkada\305\237\304\261n\304\261zla payla\305\237t\304\261\304\237\304\261n\304\261z davet linki ve ortak \305\237ifre ile buraya ba\304\237lanabilirsiniz. G\303\266nderilen t\303\274m mesajlar u\303\247tan uca \305\237ifrelenir.\n                  </p>\n                  \n                  {/* Share button in empty space */}\n                  <button\n                    onClick={copyShareLink}\n                    className=\"mt-4 inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-slate-950 text-xs font-bold rounded-lg shadow-md transition-colors cursor-pointer\"\n                  >\n                    <Share2 size={13} /> Davet Linkini Kopyala\n                  </button>\n                </div>\n              ) : (\n                <div className=\"flex flex-col gap-3\">\n                  {messages.map((msg) => {\n                    const isMe = msg.sender === roomConfig.username;\n                    return (\n                      <motion.div\n                        key={msg.id}\n                        initial={{ opacity: 0, y: 10 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        className={`flex flex-col max-w-[85%] ${isMe ? \"self-end items-end\" : \"self-start items-start\"}`}\n                        onMouseEnter={() => setHoveredMessageId(msg.id)}\n                        onMouseLeave={() => setHoveredMessageId(null)}\n                      >\n                        {/* Username tag */}\n                        <span className=\"text-[11px] text-slate-500 font-semibold mb-1 ml-1 px-1\">\n                          {isMe ? \"Siz\" : msg.sender}\n                        </span>\n\n                        {/* Message box */}\n                        <div\n                          className={`p-3 rounded-2xl relative shadow-md group border transition-all ${\n                            isMe\n                              ? \"bg-emerald-500 text-slate-950 border-emerald-400/20 rounded-tr-none\"\n                              : \"bg-slate-900 text-slate-200 border-slate-800 rounded-tl-none\"\n                          }`}\n                        >\n                          {/* Main decrypted body */}\n                          <p className=\"text-sm leading-relaxed break-words font-sans whitespace-pre-wrap font-medium\">\n                            {msg.text}\n                          </p>\n\n                          {/* Info Pill & Timestamp footer */}\n                          <div className={`flex items-center justify-between gap-3 mt-1.5 text-[10px] ${\n                            isMe ? \"text-slate-950/70\" : \"text-slate-500\"\n                          }`}>\n                            <span>{formatTime(msg.timestamp)}</span>\n                            \n                            {/* Toggle Meta details */}\n                            <button\n                              onClick={() => setVisibleMetaMsgId(visibleMetaMsgId === msg.id ? null : msg.id)}\n                              className=\"inline-flex items-center gap-0.5 hover:underline font-mono text-[9px] cursor-pointer\"\n                              title=\"\305\236ifreli veriyi ve IV parametrelerini g\303\266r\"\n                            >\n                              <Lock size={9} />\n                              <span>{visibleMetaMsgId === msg.id ? \"Gizle\" : \"Kripto Detay\"}</span>\n                            </button>\n                          </div>\n                        </div>\n\n                        {/* Interactive Crypto Details Container (Cyber-security terminal visualizer) */}\n                        <AnimatePresence>\n                          {visibleMetaMsgId === msg.id && (\n                            <motion.div\n                              initial={{ opacity: 0, height: 0 }}\n                              animate={{ opacity: 1, height: \"auto\" }}\n                              exit={{ opacity: 0, height: 0 }}\n                              className=\"w-full mt-2 overflow-hidden text-left\"\n                            >\n                              <div className=\"p-3 bg-slate-950 border border-emerald-500/20 rounded-xl text-[10px] font-mono text-emerald-400 space-y-2 max-w-full overflow-x-auto shadow-inner leading-relaxed\">\n                                <div className=\"flex justify-between items-center border-b border-emerald-500/10 pb-1\">\n                                  <span className=\"font-bold uppercase text-emerald-300\">\360\237\224\222 U\303\207TAN UCA \305\236\304\260FREL\304\260 PARAMETRELER</span>\n                                  <span className=\"text-[9px] px-1 bg-emerald-500/10 rounded\">AES-GCM-256</span>\n                                </div>\n                                <div className=\"space-y-1\">\n                                  <div>\n                                    <span className=\"text-emerald-500 font-semibold\">G\303\266nderen:</span> {msg.sender}\n                                  </div>\n                                  <div>\n                                    <span className=\"text-emerald-500 font-semibold\">Zaman Damgas\304\261:</span> {msg.timestamp}\n                                  </div>\n                                  <div className=\"break-all whitespace-pre-wrap\">\n                                    <span className=\"text-emerald-500 font-semibold\">GCM Ba\305\237latma Vekt\303\266r\303\274 (IV):</span>\n                                    <div className=\"mt-0.5 p-1 bg-slate-900 rounded border border-slate-800 text-[9px] text-slate-300 select-all\">\n                                      {msg.iv}\n                                    </div>\n                                  </div>\n                                  <div className=\"break-all whitespace-pre-wrap\">\n                                    <span className=\"text-emerald-500 font-semibold\">Base64 \305\236ifreli G\303\266vde (Ciphertext):</span>\n                                    <div className=\"mt-0.5 p-1 bg-slate-900 rounded border border-slate-800 text-[9px] text-slate-300 select-all\">\n                                      {msg.ciphertext}\n                                    </div>\n                                  </div>\n                                  <div className=\"text-[9px] text-emerald-500/70 border-t border-emerald-500/10 pt-1 flex items-center gap-1.5\">\n                                    <Shield size={10} />\n                                    <span>B\303\274t\303\274nl\303\274k Do\304\237ruland\304\261 (GCM Etiketi Ge\303\247erli)</span>\n                                  </div>\n                                </div>\n                              </div>\n                            </motion.div>\n                          )}\n                        </AnimatePresence>\n                      </motion.div>\n                    );\n                  })}\n                </div>\n              )}\n              <div ref={messageEndRef} />\n            </div>\n\n            {/* Chat bottom input area */}\n            <div className=\"bg-slate-900/80 backdrop-blur-md border-x border-b border-slate-800 p-4 rounded-b-2xl shadow-lg\">\n              <form onSubmit={handleSendMessage} className=\"flex gap-2\">\n                <input\n                  type=\"text\"\n                  value={inputText}\n                  onChange={(e) => setInputText(e.target.value)}\n                  placeholder=\"G\303\274venli, \305\237ifreli mesaj\304\261n\304\261z\304\261 yaz\304\261n...\"\n                  className=\"flex-1 bg-slate-950/80 border border-slate-800 focus:border-emerald-500/50 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none transition-colors\"\n                  disabled={sseStatus !== \"connected\"}\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!inputText.trim() || sseStatus !== \"connected\" || isSending}\n                  className=\"px-5 bg-emerald-500 hover:bg-emerald-400 disabled:bg-slate-800 disabled:text-slate-500 text-slate-950 font-bold rounded-xl flex items-center justify-center transition-all cursor-pointer disabled:cursor-not-allowed shadow-md hover:shadow-emerald-500/10 active:scale-95\"\n                  title=\"Mesaj\304\261 \305\237ifrele ve g\303\266nder\"\n                >\n                  <Send size={16} className={isSending ? \"animate-pulse\" : \"\"} />\n                </button>\n              </form>\n\n              {/* Status Alert or Error Banner */}\n              {errorText && (\n                <p className=\"text-rose-400 text-xs mt-2 text-center font-medium\">\n                  {errorText}\n                </p>\n              )}\n              \n              <div className=\"mt-2.5 flex items-center justify-between text-[11px] text-slate-500\">\n                <div className=\"flex items-center gap-1.5\">\n                  <Shield size={12} className=\"text-emerald-500/70\" />\n                  <span>\305\236ifreleme modu: <span className=\"text-emerald-500 font-semibold font-mono\">CLIENT AES-GCM (256-bit)</span></span>\n                </div>\n                <span>Mesajlar sunucuya asla d\303\274z metin olarak gitmez.</span>\n              </div>\n            </div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </div>\n  );"
        replacement_content: "  return (\n    <div className=\"min-h-screen bg-[#fdfdfd] text-[#1a1a1a] flex flex-col font-sans selection:bg-indigo-100 selection:text-indigo-900 relative\">\n      \n      {/* Background elegant grid pattern for minimal look */}\n      <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none opacity-40\" />\n\n      {/* Main container */}\n      <AnimatePresence mode=\"wait\">\n        {!roomConfig ? (\n          // ================== ACCESS / CONFIGURATION SCREEN ==================\n          <motion.div\n            key=\"login\"\n            initial={{ opacity: 0, y: 15 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: -15 }}\n            className=\"flex-1 flex items-center justify-center p-4 z-10\"\n          >\n            <div className=\"w-full max-w-md bg-white border border-gray-100 rounded-2xl shadow-sm p-6 md:p-8\">\n              \n              {/* Security Shield Header */}\n              <div className=\"flex flex-col items-center text-center mb-6\">\n                <div className=\"p-3 bg-indigo-50 border border-indigo-100 text-indigo-600 rounded-full mb-3 shadow-sm\">\n                  <Shield size={32} />\n                </div>\n                <h1 className=\"text-2xl font-bold tracking-tight text-gray-900 font-sans\">Kripto Sohbet</h1>\n                <p className=\"text-xs text-gray-500 mt-1 max-w-sm\">\n                  U\303\247tan uca \305\237ifreli (E2EE), tamamen gizli ve anl\304\261k mesajla\305\237ma platformu. Sunucu mesajlar\304\261n\304\261z\304\261 asla okuyamaz.\n                </p>\n              </div>\n\n              {/* Informative Security Alert */}\n              <div className=\"mb-6 p-3 bg-gray-50 border border-gray-100 rounded-lg text-xs text-gray-600 flex items-start gap-2.5\">\n                <Info size={16} className=\"text-indigo-600 flex-shrink-0 mt-0.5\" />\n                <p className=\"leading-relaxed\">\n                  Mesajlar\304\261n\304\261z taray\304\261c\304\261da <span className=\"text-indigo-600 font-semibold font-mono\">AES-GCM 256-bit</span> ile \305\237ifrelenir.\n                  Arkada\305\237\304\261n\304\261zla ayn\304\261 <span className=\"text-indigo-600 font-semibold\">Ortak \305\236ifreyi</span> kullanarak mesajlar\304\261 an\304\261nda de\305\237ifre edebilirsiniz.\n                </p>\n              </div>\n\n              <form onSubmit={handleJoinRoom} className=\"space-y-4\">\n                {/* Username Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-gray-700 flex justify-between items-center\">\n                    <span>Rumuzunuz (Kullan\304\261c\304\261 Ad\304\261)</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setUsernameInput(generateRandomUsername())}\n                      className=\"text-[10px] text-indigo-600 hover:text-indigo-700 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> Rastgele \303\234ret\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <User size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={usernameInput}\n                      onChange={(e) => setUsernameInput(e.target.value)}\n                      placeholder=\"\303\226rn: G\303\266lgeAjan\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-gray-50/50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white transition-all font-sans\"\n                    />\n                  </div>\n                </div>\n\n                {/* Room ID Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-gray-700 flex justify-between items-center\">\n                    <span>Oda Ad\304\261 (Oda Kodu)</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setRoomInput(generateRandomRoomId())}\n                      className=\"text-[10px] text-indigo-600 hover:text-indigo-700 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> Rastgele Olu\305\237tur\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <Lock size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={roomInput}\n                      onChange={(e) => setRoomInput(e.target.value.toLowerCase().replace(/\\s+/g, \"-\"))}\n                      placeholder=\"\303\226rn: ozel-sohbet-odasi\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-gray-50/50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white transition-all font-mono\"\n                    />\n                  </div>\n                </div>\n\n                {/* Private Encryption Password Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-gray-700 flex justify-between items-center\">\n                    <span>Ortak \305\236ifreleme Anahtar\304\261</span>\n                    <button\n                      type=\"button\"\n                      onClick={() => setPasswordInput(generateRandomPassword())}\n                      className=\"text-[10px] text-indigo-600 hover:text-indigo-700 flex items-center gap-1 transition-colors\"\n                    >\n                      <Sparkles size={10} /> G\303\274\303\247l\303\274 \305\236ifre \303\234ret\n                    </button>\n                  </label>\n                  <div className=\"relative\">\n                    <Key size={16} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" />\n                    <input\n                      type=\"text\"\n                      required\n                      value={passwordInput}\n                      onChange={(e) => setPasswordInput(e.target.value)}\n                      placeholder=\"\305\236ifreleme anahtar\304\261n\304\261 buraya girin...\"\n                      className=\"w-full pl-9 pr-4 py-2.5 bg-gray-50/50 border border-gray-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white transition-all font-mono\"\n                    />\n                  </div>\n                </div>\n\n                {errorText && (\n                  <p className=\"text-red-500 text-xs text-center font-medium mt-1\">\n                    {errorText}\n                  </p>\n                )}\n\n                <button\n                  type=\"submit\"\n                  className=\"w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg text-sm transition-all duration-200 active:scale-[0.98] shadow-sm shadow-indigo-600/10 flex items-center justify-center gap-2 mt-2 cursor-pointer\"\n                >\n                  <Lock size={16} /> G\303\274venli Giri\305\237 Yap\n                </button>\n              </form>\n            </div>\n          </motion.div>\n        ) : (\n          // ================== ACTIVE CHAT ROOM SCREEN ==================\n          <motion.div\n            key=\"chat\"\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            exit={{ opacity: 0 }}\n            className=\"flex-1 flex flex-col max-w-5xl w-full mx-auto p-3 md:p-6 z-10\"\n          >\n            {/* Upper Room Header Dashboard */}\n            <div className=\"bg-white border border-gray-100 rounded-t-2xl p-4 flex flex-col md:flex-row gap-3 items-start md:items-center justify-between shadow-sm\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"p-2.5 bg-indigo-50 border border-indigo-100 text-indigo-600 rounded-lg\">\n                  <Lock size={20} />\n                </div>\n                <div>\n                  <div className=\"flex items-center gap-2\">\n                    <h2 className=\"text-md font-bold text-gray-900 tracking-tight font-mono\">\n                      {roomConfig.roomId}\n                    </h2>\n                    <span\n                      className={`inline-block w-2.5 h-2.5 rounded-full ${\n                        sseStatus === \"connected\"\n                          ? \"bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]\"\n                          : sseStatus === \"connecting\"\n                          ? \"bg-amber-500 animate-pulse\"\n                          : \"bg-red-500\"\n                      }`}\n                      title={\n                        sseStatus === \"connected\"\n                          ? \"Canl\304\261 ba\304\237lant\304\261 aktif\"\n                          : sseStatus === \"connecting\"\n                          ? \"Ba\304\237lant\304\261 kuruluyor...\"\n                          : \"Ba\304\237lant\304\261 koptu\"\n                      }\n                    />\n                  </div>\n                  <p className=\"text-xs text-gray-500 flex items-center gap-1.5 mt-0.5\">\n                    Rumuz: <span className=\"text-indigo-600 font-semibold\">{roomConfig.username}</span>\n                  </p>\n                </div>\n              </div>\n\n              {/* Action utilities */}\n              <div className=\"flex flex-wrap items-center gap-2 w-full md:w-auto\">\n                {/* Share Link Button */}\n                <button\n                  onClick={copyShareLink}\n                  className=\"flex-1 md:flex-initial flex items-center justify-center gap-1.5 px-3 py-1.5 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg text-xs text-gray-700 font-medium transition-colors cursor-pointer\"\n                >\n                  {copiedLink ? (\n                    <>\n                      <Check size={14} className=\"text-green-600\" />\n                      <span>Kopyaland\304\261!</span>\n                    </>\n                  ) : (\n                    <>\n                      <Share2 size={14} />\n                      <span>Davet Linki</span>\n                    </>\n                  )}\n                </button>\n\n                {/* Show Encryption Password Tooltip/Info */}\n                <button\n                  onClick={copyPasswordKey}\n                  className=\"flex-1 md:flex-initial flex items-center justify-center gap-1.5 px-3 py-1.5 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg text-xs text-gray-700 font-medium transition-colors font-mono cursor-pointer\"\n                  title=\"T\304\261klayarak \305\237ifreleme anahtar\304\261n\304\261 kopyalay\304\261n\"\n                >\n                  <Key size={13} className=\"text-indigo-600\" />\n                  <span>\305\236ifre:</span>\n                  <span className=\"text-gray-600 max-w-[80px] truncate\">{roomConfig.passwordKey}</span>\n                  {copiedKey ? <Check size={12} className=\"text-green-600 ml-1\" /> : <Copy size={11} className=\"text-gray-400 ml-1\" />}\n                </button>\n\n                {/* Reset room */}\n                <button\n                  onClick={handleClearHistory}\n                  className=\"p-1.5 bg-gray-50 hover:bg-red-50 border border-gray-200 hover:border-red-100 text-gray-400 hover:text-red-600 rounded-lg transition-colors cursor-pointer\"\n                  title=\"Ge\303\247mi\305\237i Tamamen S\304\261f\304\261rla (Kendi Cihazlar\304\261nda ve Sunucuda)\"\n                >\n                  <Trash2 size={15} />\n                </button>\n\n                {/* Leave room */}\n                <button\n                  onClick={() => setRoomConfig(null)}\n                  className=\"flex items-center gap-1 px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 hover:text-red-700 border border-red-100 rounded-lg text-xs font-semibold transition-colors cursor-pointer\"\n                >\n                  <LogOut size={13} />\n                  <span>\303\207\304\261k\304\261\305\237</span>\n                </button>\n              </div>\n            </div>\n\n            {/* Chat Body messages stream */}\n            <div className=\"flex-1 bg-white border-x border-gray-100 p-4 overflow-y-auto space-y-4 min-h-[400px] relative\">\n              {messages.length === 0 ? (\n                <div className=\"absolute inset-0 flex flex-col items-center justify-center p-6 text-center\">\n                  <div className=\"p-4 bg-indigo-50 rounded-full border border-indigo-100 mb-3 text-indigo-600\">\n                    <Unlock size={32} />\n                  </div>\n                  <h3 className=\"text-sm font-semibold text-gray-800\">Kripto Sohbet Odas\304\261 Haz\304\261r</h3>\n                  <p className=\"text-xs text-gray-500 mt-1 max-w-sm leading-relaxed\">\n                    Arkada\305\237\304\261n\304\261zla payla\305\237t\304\261\304\237\304\261n\304\261z davet linki ve ortak \305\237ifre ile buraya ba\304\237lanabilirsiniz. G\303\266nderilen t\303\274m mesajlar u\303\247tan uca \305\237ifrelenir.\n                  </p>\n                  \n                  {/* Share button in empty space */}\n                  <button\n                    onClick={copyShareLink}\n                    className=\"mt-4 inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg shadow-sm transition-colors cursor-pointer\"\n                  >\n                    <Share2 size={13} /> Davet Linkini Kopyala\n                  </button>\n                </div>\n              ) : (\n                <div className=\"flex flex-col gap-3\">\n                  {messages.map((msg) => {\n                    const isMe = msg.sender === roomConfig.username;\n                    return (\n                      <motion.div\n                        key={msg.id}\n                        initial={{ opacity: 0, y: 10 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        className={`flex flex-col max-w-[85%] ${isMe ? \"self-end items-end\" : \"self-start items-start\"}`}\n                        onMouseEnter={() => setHoveredMessageId(msg.id)}\n                        onMouseLeave={() => setHoveredMessageId(null)}\n                      >\n                        {/* Username tag */}\n                        <span className=\"text-[11px] text-gray-400 font-semibold mb-1 ml-1 px-1\">\n                          {isMe ? \"Siz\" : msg.sender}\n                        </span>\n\n                        {/* Message box */}\n                        <div\n                          className={`p-3 rounded-2xl relative shadow-sm group border transition-all ${\n                            isMe\n                              ? \"bg-indigo-600 text-white border-transparent rounded-tr-none\"\n                              : \"bg-gray-100 text-gray-800 border-transparent rounded-tl-none\"\n                          }`}\n                        >\n                          {/* Main decrypted body */}\n                          <p className=\"text-sm leading-relaxed break-words font-sans whitespace-pre-wrap font-medium\">\n                            {msg.text}\n                          </p>\n\n                          {/* Info Pill & Timestamp footer */}\n                          <div className={`flex items-center justify-between gap-3 mt-1.5 text-[10px] ${\n                            isMe ? \"text-indigo-100\" : \"text-gray-400\"\n                          }`}>\n                            <span>{formatTime(msg.timestamp)}</span>\n                            \n                            {/* Toggle Meta details */}\n                            <button\n                              onClick={() => setVisibleMetaMsgId(visibleMetaMsgId === msg.id ? null : msg.id)}\n                              className={`inline-flex items-center gap-0.5 hover:underline font-mono text-[9px] cursor-pointer ${\n                                isMe ? \"text-indigo-200\" : \"text-gray-500 hover:text-indigo-600\"\n                              }`}\n                              title=\"\305\236ifreli veriyi ve IV parametrelerini g\303\266r\"\n                            >\n                              <Lock size={9} />\n                              <span>{visibleMetaMsgId === msg.id ? \"Gizle\" : \"Kripto Detay\"}</span>\n                            </button>\n                          </div>\n                        </div>\n\n                        {/* Interactive Crypto Details Container (Cyber-security terminal visualizer) */}\n                        <AnimatePresence>\n                          {visibleMetaMsgId === msg.id && (\n                            <motion.div\n                              initial={{ opacity: 0, height: 0 }}\n                              animate={{ opacity: 1, height: \"auto\" }}\n                              exit={{ opacity: 0, height: 0 }}\n                              className=\"w-full mt-2 overflow-hidden text-left\"\n                            >\n                              <div className=\"p-3 bg-gray-50 border border-indigo-100 rounded-xl text-[10px] font-mono text-gray-600 space-y-2 max-w-full overflow-x-auto shadow-sm leading-relaxed\">\n                                <div className=\"flex justify-between items-center border-b border-indigo-100/30 pb-1\">\n                                  <span className=\"font-bold uppercase text-indigo-700\">\360\237\224\222 U\303\207TAN UCA \305\236\304\260FREL\304\260 PARAMETRELER</span>\n                                  <span className=\"text-[9px] px-1 bg-indigo-50 text-indigo-700 rounded font-bold\">AES-GCM-256</span>\n                                </div>\n                                <div className=\"space-y-1\">\n                                  <div>\n                                    <span className=\"text-indigo-600 font-semibold\">G\303\266nderen:</span> {msg.sender}\n                                  </div>\n                                  <div>\n                                    <span className=\"text-indigo-600 font-semibold\">Zaman Damgas\304\261:</span> {msg.timestamp}\n                                  </div>\n                                  <div className=\"break-all whitespace-pre-wrap\">\n                                    <span className=\"text-indigo-600 font-semibold\">GCM Ba\305\237latma Vekt\303\266r\303\274 (IV):</span>\n                                    <div className=\"mt-0.5 p-1 bg-white rounded border border-gray-100 text-[9px] text-gray-700 select-all\">\n                                      {msg.iv}\n                                    </div>\n                                  </div>\n                                  <div className=\"break-all whitespace-pre-wrap\">\n                                    <span className=\"text-indigo-600 font-semibold\">Base64 \305\236ifreli G\303\266vde (Ciphertext):</span>\n                                    <div className=\"mt-0.5 p-1 bg-white rounded border border-gray-100 text-[9px] text-gray-700 select-all\">\n                                      {msg.ciphertext}\n                                    </div>\n                                  </div>\n                                  <div className=\"text-[9px] text-indigo-600/70 border-t border-indigo-100/30 pt-1 flex items-center gap-1.5\">\n                                    <Shield size={10} />\n                                    <span>B\303\274t\303\274nl\303\274k Do\304\237ruland\304\261 (GCM Etiketi Ge\303\247erli)</span>\n                                  </div>\n                                </div>\n                              </div>\n                            </motion.div>\n                          )}\n                        </AnimatePresence>\n                      </motion.div>\n                    );\n                  })}\n                </div>\n              )}\n              <div ref={messageEndRef} />\n            </div>\n\n            {/* Chat bottom input area */}\n            <div className=\"bg-white border-x border-b border-gray-100 p-4 rounded-b-2xl shadow-sm\">\n              <form onSubmit={handleSendMessage} className=\"flex gap-2\">\n                <input\n                  type=\"text\"\n                  value={inputText}\n                  onChange={(e) => setInputText(e.target.value)}\n                  placeholder=\"G\303\274venli, \305\237ifreli mesaj\304\261n\304\261z\304\261 yaz\304\261n...\"\n                  className=\"flex-1 bg-gray-50 border border-gray-200 focus:border-indigo-500/50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:bg-white transition-all\"\n                  disabled={sseStatus !== \"connected\"}\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!inputText.trim() || sseStatus !== \"connected\" || isSending}\n                  className=\"px-5 bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-100 disabled:text-gray-400 text-white font-bold rounded-xl flex items-center justify-center transition-all cursor-pointer disabled:cursor-not-allowed shadow-sm hover:shadow-indigo-600/10 active:scale-95\"\n                  title=\"Mesaj\304\261 \305\237ifrele ve g\303\266nder\"\n                >\n                  <Send size={16} className={isSending ? \"animate-pulse\" : \"\"} />\n                </button>\n              </form>\n\n              {/* Status Alert or Error Banner */}\n              {errorText && (\n                <p className=\"text-red-500 text-xs mt-2 text-center font-medium\">\n                  {errorText}\n                </p>\n              )}\n              \n              <div className=\"mt-2.5 flex items-center justify-between text-[11px] text-gray-400\">\n                <div className=\"flex items-center gap-1.5\">\n                  <Shield size={12} className=\"text-indigo-500/70\" />\n                  <span>\305\236ifreleme modu: <span className=\"text-indigo-600 font-semibold font-mono\">CLIENT AES-GCM (256-bit)</span></span>\n                </div>\n                <span>Mesajlar sunucuya asla d\303\274z metin olarak gitmez.</span>\n              </div>\n            </div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </div>\n  );"
      }
      num_matches: 1
    }
  }
}
